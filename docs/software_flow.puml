@startuml software_flow
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam dpi 150

skinparam rectangle {
  BorderColor #333333
  BackgroundColor #F8F8F8
}

skinparam database {
  BorderColor #333333
  BackgroundColor #FFF8DC
}

skinparam cloud {
  BorderColor #333333
  BackgroundColor #EEF5FF
}

skinparam component {
  BorderColor #333333
  BackgroundColor #EFFAF0
}

title Диаграмма программного потока (API + JWT)

actor "Пользователь" as U

rectangle "Фронтенд (браузер)" as FE {
  component "UI / index.html\n(модальные окна)" as UI
  component "script.js\n(логика калькулятора,\nFetch API)" as APP
  component "charactersData.js\n(загрузка персонажей)" as CHARS_JS
  component "artifacts.js\n(редактор реликвий)" as ARTIFACTS_JS
}

cloud "Express API" as BE {
  component "auth routes\n/api/auth/*\n(register, login, me)" as R_AUTH
  component "builds routes\n/api/builds/*\n(CRUD + tags)" as R_BUILDS
  component "characters routes\n/api/characters/*" as R_CHARS
  component "relics routes\n/api/relics/*\n(sets, items, stats)" as R_RELICS
  component "JWT middleware\n(requireAuth/optionalAuth)" as MW
}

database "PostgreSQL" as DB {
  rectangle "users" as T_USERS
  rectangle "builds" as T_BUILDS
  rectangle "build_pieces" as T_PIECES
  rectangle "build_substats" as T_SUBS
  rectangle "tags + build_tags" as T_TAGS
  rectangle "characters, relic_sets, relic_items, stats" as T_DICT
}

U --> UI : выбирает персонажа/реликвии
UI --> APP : события интерфейса (клики, форм)
APP --> APP : локальный расчет шансов выпадения
APP --> CHARS_JS : загрузить данные
CHARS_JS --> API : GET /api/characters
ARTIFACTS_JS --> API : GET /api/relics, /api/relics/stats
APP --> API : POST /api/builds (сохранение)
APP --> API : PUT /api/builds/:id (редактирование)
APP --> API : DELETE /api/builds/:id (удаление)
APP --> API : GET /api/builds/public (просмотр)

API --> R_AUTH : /api/auth/register, /api/auth/login, /api/auth/me
API --> R_BUILDS : /api/builds/* (CRUD операции)
API --> R_CHARS : /api/characters/*
API --> R_RELICS : /api/relics/*

R_AUTH --> MW : проверка JWT
R_BUILDS --> MW : проверка JWT (для защищенных endpoint-ов)

R_BUILDS --> DB : INSERT/UPDATE/DELETE билдов
R_AUTH --> DB : SELECT/INSERT users
R_CHARS --> DB : SELECT characters
R_RELICS --> DB : SELECT relic_sets, relic_items, stats

DB --> R_BUILDS : данные билдов + tags
DB --> R_AUTH : user данные
DB --> R_CHARS : characters
DB --> R_RELICS : sets/items/stats

R_BUILDS --> API : JSON (build с share_code, pieces, tags)
R_AUTH --> API : JWT token, user data
R_CHARS --> API : characters array
R_RELICS --> API : sets/items/stats

API --> APP : JSON (в script.js)
API --> CHARS_JS : characters
API --> ARTIFACTS_JS : relics data
APP --> UI : обновление интерфейса

@enduml
