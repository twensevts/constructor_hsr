digraph UserFlow {
    rankdir=TB;
    splines=ortho;
    graph [fontname="Arial", fontsize=12, label="Диаграмма пользовательского потока (API + авторизация)", labelloc=t];
    node [fontname="Arial", fontsize=10, shape=box, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
    edge [fontname="Arial", fontsize=9, color="#333333"];

    Start [label="Начало", shape=ellipse, style="filled", fillcolor="#333333", fontcolor="#ffffff"];
    End [label="Конец", shape=ellipse, style="filled", fillcolor="#333333", fontcolor="#ffffff"];

    u1 [label="Открыть приложение"];
    u2 [label="Выбрать персонажа"];
    d1 [label="Есть аккаунт?", shape=diamond, fillcolor="#FFF8E1", color="#E6A817"];
    u3 [label="Нажать 'Войти' и отправить /api/auth/login"];
    d2 [label="Логин успешен?", shape=diamond, fillcolor="#FFF8E1", color="#E6A817"];
    u4 [label="Сохранить access token"];
    u5 [label="Продолжить как гость"];

    u6 [label="Выбрать сет, главный стат, подстаты"];
    u7 [label="Рассчитать шанс выпадения"];
    d3 [label="Сохранить билд?", shape=diamond, fillcolor="#FFF8E1", color="#E6A817"];
    d4 [label="Авторизован?", shape=diamond, fillcolor="#FFF8E1", color="#E6A817"];
    u8 [label="POST /api/builds"];
    u9 [label="Получить id и share-код"];
    d5 [label="Редактировать позже?", shape=diamond, fillcolor="#FFF8E1", color="#E6A817"];
    u10 [label="PUT /api/builds/:id"];
    d6 [label="Удалить билд?", shape=diamond, fillcolor="#FFF8E1", color="#E6A817"];
    u11 [label="DELETE /api/builds/:id"];
    u12 [label="Показать запрос на вход"];

    d7 [label="Открыть по share-ссылке?", shape=diamond, fillcolor="#FFF8E1", color="#E6A817"];
    u13 [label="GET /api/builds/share/:code"];
    u14 [label="Просмотр публичной сборки"];
    u15 [label="Фильтрация публичных билдов: GET /api/builds/public"];

    Start -> u1 -> u2 -> d1;
    d1 -> u3 [label="да"];
    u3 -> d2;
    d2 -> u4 [label="да"];
    d2 -> End [label="нет"];
    d1 -> u5 [label="нет"];

    u4 -> u6;
    u5 -> u6;
    u6 -> u7 -> d3;
    d3 -> d4 [label="да"];
    d3 -> d7 [label="нет"];

    d4 -> u8 [label="да"];
    d4 -> u12 [label="нет"];
    u8 -> u9 -> d5;
    d5 -> u10 [label="да"];
    d5 -> d6 [label="нет"];
    u10 -> d6;
    d6 -> u11 [label="да"];
    d6 -> d7 [label="нет"];
    u11 -> d7;
    u12 -> d7;

    d7 -> u13 [label="да"];
    u13 -> u14 -> u15 -> End;
    d7 -> u15 [label="нет"];
}
