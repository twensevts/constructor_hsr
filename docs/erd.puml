@startuml erd
hide circle
skinparam linetype ortho
skinparam classAttributeIconSize 0

entity "users" as users {
  *id : uuid <<PK>>
  --
  email : text <<UQ>>
  password_hash : text
  created_at : timestamptz
}

entity "builds" as builds {
  *id : uuid <<PK>>
  --
  user_id : uuid <<FK users.id>>
  character_id : int <<FK characters.id>>
  title : text
  notes : text
  is_public : boolean
  share_code : text <<UQ>>
  created_at : timestamptz
  updated_at : timestamptz
}

entity "build_pieces" as build_pieces {
  *id : uuid <<PK>>
  --
  build_id : uuid <<FK builds.id>>
  slot : text
  item_id : int <<FK relic_items.id>>
  main_stat_id : int <<FK stats.id>>
  level : int
  obtained : boolean
}

entity "build_substats" as build_substats {
  *id : uuid <<PK>>
  --
  piece_id : uuid <<FK build_pieces.id>>
  stat_id : int <<FK stats.id>>
  value : numeric
  rolls : int
}

entity "tags" as tags {
  *id : uuid <<PK>>
  --
  user_id : uuid <<FK users.id>>
  name : text
}

entity "build_tags" as build_tags {
  *build_id : uuid <<FK builds.id>>
  *tag_id : uuid <<FK tags.id>>
}

entity "characters" as characters {
  *id : int <<PK>>
  --
  key : text <<UQ>>
  name : text
  rarity : int
  path : text
  element : text
}

entity "relic_sets" as relic_sets {
  *id : int <<PK>>
  --
  key : text <<UQ>>
  name : text
  rarity : int
}

entity "relic_items" as relic_items {
  *id : int <<PK>>
  --
  set_id : int <<FK relic_sets.id>>
  slot : text
  name : text
}

entity "stats" as stats {
  *id : int <<PK>>
  --
  key : text <<UQ>>
  name : text
  kind : text
}

users |o--o{ builds : "owns"
users ||--o{ tags : "creates"
builds ||--|{ build_pieces : "contains"
build_pieces ||--o{ build_substats : "has"
builds ||--o{ build_tags : "tagged"
tags ||--o{ build_tags : "mapping"
characters ||--o{ builds : "for character"
relic_sets ||--|{ relic_items : "includes"
relic_items |o--o{ build_pieces : "selected"
stats |o--o{ build_pieces : "main stat"
stats ||--o{ build_substats : "sub stat"

note right of builds
is_public=true -> виден в /public
share_code -> доступ по /share/:code
end note

@enduml
