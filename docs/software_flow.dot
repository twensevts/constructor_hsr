digraph SoftwareFlow {
    rankdir=TB;
    splines=ortho;
    graph [fontname="Arial", fontsize=12, label="Диаграмма программного потока (API + JWT)", labelloc=t];
    node [fontname="Arial", fontsize=10, shape=box, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
    edge [fontname="Arial", fontsize=9, color="#333333"];

    Start [label="Начало", shape=ellipse, style="filled", fillcolor="#333333", fontcolor="#ffffff"];
    End [label="Конец", shape=ellipse, style="filled", fillcolor="#333333", fontcolor="#ffffff"];

    n1 [label="Инициализация приложения"];
    n2 [label="Promise.all(loadCharacters, loadRelicData)"];
    n3 [label="GET /api/characters"];
    d1 [label="Персонажи загружены?", shape=diamond, fillcolor="#FFF8E1", color="#E6A817"];
    n4 [label="Показать ошибку загрузки"];
    n5 [label="Инициализация UI и локальных данных реликвий"];
    d2 [label="Есть share param?", shape=diamond, fillcolor="#FFF8E1", color="#E6A817"];
    n6 [label="GET /api/builds/:id"];
    d3 [label="Билд доступен?", shape=diamond, fillcolor="#FFF8E1", color="#E6A817"];
    n7 [label="Открыть билд в режиме read-only"];
    n8 [label="Загрузить локальные сеты и отрисовать"];
    n9 [label="Ожидание событий UI"];

    n10 [label="Создать/редактировать билд\\nupdateCardDisplay + calculateDropChance\\nPOST /api/builds"];
    n11 [label="Auth flow\\nPOST /api/auth/register|login\\nGET /api/auth/me"];
    n12 [label="API личных билдов\\nGET/PUT/PATCH/DELETE /api/builds"];

    n13 [label="Маршрутизация backend и middleware"];
    d4 [label="Требуется авторизация?", shape=diamond, fillcolor="#FFF8E1", color="#E6A817"];
    n14 [label="requireAuth / optionalAuth"];
    n15 [label="SQL-запросы в PostgreSQL"];
    n16 [label="JSON-ответ"];
    n17 [label="showShareModal(build.id)"];

    Start -> n1 -> n2 -> n3 -> d1;
    d1 -> n4 [label="нет"];
    n4 -> End;
    d1 -> n5 [label="да"];
    n5 -> d2;
    d2 -> n6 [label="да"];
    n6 -> d3;
    d3 -> n7 [label="да"];
    d3 -> n9 [label="нет"];
    n7 -> n9;
    d2 -> n8 [label="нет"];
    n8 -> n9;

    n9 -> n10;
    n9 -> n11;
    n9 -> n12;

    n10 -> n13;
    n11 -> n13;
    n12 -> n13;

    n13 -> d4;
    d4 -> n14 [label="да"];
    d4 -> n14 [label="нет"];
    n14 -> n15 -> n16;
    n16 -> n17;
    n17 -> n9;
}
