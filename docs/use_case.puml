@startuml use_case
left to right direction
skinparam linetype polyline
skinparam nodesep 70
skinparam ranksep 80
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam backgroundColor white
skinparam ArrowColor #333333

skinparam usecase {
  BackgroundColor #EEF4FA
  BorderColor #4A7FA5
  FontColor #1A1A1A
}

skinparam actor {
  BorderColor #333333
  FontColor #1A1A1A
}

title Диаграмма вариантов использования - API и авторизация

actor "Гость" as Guest
actor "Авторизованный пользователь" as User

rectangle "Система: HSR Relic Calculator" {
  usecase "Просматривать\nпубличные билды" as UC_ViewPublic
  usecase "Открывать билд\nпо share-ссылке" as UC_OpenShare
  usecase "Зарегистрироваться" as UC_Register
  usecase "Войти" as UC_Login
  usecase "Получить профиль" as UC_Profile

  usecase "Создать билд" as UC_CreateBuild
  usecase "Редактировать свой билд" as UC_EditBuild
  usecase "Удалить свой билд" as UC_DeleteBuild
  usecase "Отметить предмет\nкак полученный" as UC_MarkObtained
  usecase "Управлять тегами" as UC_ManageTags

  usecase "Настроить\nартефакты" as UC_ConfigArtifacts
  usecase "Выбрать сет реликвий" as UC_SelectSet
  usecase "Выбрать главный стат" as UC_SelectMain
  usecase "Выбрать подстаты" as UC_SelectSub
  usecase "Рассчитать шанс\nвыпадения" as UC_CalcChance
  usecase "Сохранить билд\nв API" as UC_SaveApi
  usecase "Получить share-ссылку" as UC_Share
}

Guest --> UC_ViewPublic
Guest --> UC_OpenShare
Guest --> UC_Register
Guest --> UC_Login
Guest --> UC_CreateBuild

User --> UC_Profile
User --> UC_CreateBuild
User --> UC_EditBuild
User --> UC_DeleteBuild
User --> UC_MarkObtained
User --> UC_ViewPublic
User --> UC_OpenShare

UC_Login ..> UC_Profile : <<include>>

UC_CreateBuild -[hidden]down-> UC_EditBuild
UC_ConfigArtifacts -[hidden]down-> UC_SaveApi
UC_SaveApi -[hidden]down-> UC_ManageTags
UC_ManageTags -[hidden]down-> UC_Share
UC_CreateBuild -[hidden]right-> UC_ConfigArtifacts
UC_EditBuild -[hidden]right-> UC_SaveApi

UC_CreateBuild .right.> UC_ConfigArtifacts : <<include>>
UC_CreateBuild .right.> UC_SaveApi : <<include>>
UC_CreateBuild .right.> UC_ManageTags : <<include>>
UC_CreateBuild .right.> UC_Share : <<extend>>

UC_EditBuild .right.> UC_ConfigArtifacts : <<include>>
UC_EditBuild .right.> UC_SaveApi : <<include>>
UC_EditBuild .right.> UC_ManageTags : <<include>>
UC_EditBuild .right.> UC_Share : <<extend>>

UC_ConfigArtifacts ..> UC_SelectSet : <<include>>
UC_ConfigArtifacts ..> UC_SelectMain : <<include>>
UC_ConfigArtifacts ..> UC_SelectSub : <<include>>
UC_CalcChance ..> UC_ConfigArtifacts : <<extend>>

note right of UC_CalcChance
  Условие расширения:
  выбраны сет и главный стат
end note

@enduml
