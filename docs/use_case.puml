@startuml use_case
left to right direction
skinparam linetype ortho
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam ranksep 130
skinparam nodesep 80

actor "Гость" as Guest
actor "Авторизованный пользователь" as User

rectangle "HSR Relic Calculator" {
  rectangle "Старт и навигация" {
    usecase "Главный экран:\nсписок сетов\n(по умолчанию Мои)" as UC_Home
    usecase "Публичный режим:\nпросмотр каталога" as UC_ViewPublic
    usecase "Открытие share-ссылки\n(read-only)" as UC_OpenShare
    usecase "Регистрация/вход/выход" as UC_Auth
  }

  rectangle "Работа с сетами" {
    usecase "Создание/редактирование\nличного сета" as UC_EditPersonalBuild
    usecase "Выбор персонажа\nдля нового сета" as UC_ChooseCharacter
    usecase "Управление\nпубличностью сета" as UC_ChangeVisibility
    usecase "Удаление\nличного сета" as UC_DeleteBuild
    usecase "Импорт публичного\nсета в личные" as UC_ImportPublic
    usecase "Лайк/снятие лайка\nпубличного сета" as UC_Like
  }

  rectangle "Системные зависимости" {
    usecase "Локальное хранение\n(localStorage)" as UC_LocalStorage
    usecase "Серверное хранение\n(API + PostgreSQL)" as UC_ServerStorage
    usecase "Проверка владельца\n(user token или creator key)" as UC_OwnershipCheck
    usecase "Нормализация setId\nчерез relic_items" as UC_SetIdNormalize
  }
}

Guest --> UC_Home
User --> UC_Home

UC_EditPersonalBuild .> UC_Home : <<extend>>
UC_ViewPublic .> UC_Home : <<extend>>
UC_OpenShare .> UC_Home : <<extend>>
UC_Auth .> UC_Home : <<extend>>

UC_EditPersonalBuild .> UC_ChooseCharacter : <<include>>
UC_ChangeVisibility .> UC_EditPersonalBuild : <<extend>>
UC_DeleteBuild .> UC_EditPersonalBuild : <<extend>>
UC_ImportPublic .> UC_ViewPublic : <<extend>>
UC_Like .> UC_ViewPublic : <<extend>>
User --> UC_Like

UC_Home -[hidden]down-> UC_EditPersonalBuild
UC_EditPersonalBuild -[hidden]down-> UC_ImportPublic
UC_LocalStorage -[hidden]down-> UC_ServerStorage
UC_ServerStorage -[hidden]down-> UC_OwnershipCheck
UC_OwnershipCheck -[hidden]down-> UC_SetIdNormalize

UC_LocalStorage .> UC_EditPersonalBuild : <<extend>>
UC_ServerStorage .> UC_EditPersonalBuild : <<extend>>
UC_DeleteBuild .> UC_OwnershipCheck : <<include>>
UC_EditPersonalBuild .> UC_SetIdNormalize : <<include>>
UC_ServerStorage .> UC_ImportPublic : <<extend>> [если авторизован]
UC_LocalStorage .> UC_ImportPublic : <<extend>> [если гость]
UC_Like .> UC_ServerStorage : <<include>>
UC_ViewPublic .> UC_ServerStorage : <<include>>

note right of UC_LocalStorage
  Гостевой режим:
  сохранение/чтение/удаление
  без авторизации.
end note

note right of UC_ServerStorage
  Аккаунтный режим:
  REST API -> PostgreSQL.
  Для анонимных серверных записей
  используется creator key.
end note

@enduml

