@startuml user_flow
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam backgroundColor white
skinparam ArrowColor #333333

skinparam activity {
    BackgroundColor #EEF4FA
    BorderColor #4A7FA5
    FontColor #1A1A1A
    DiamondBackgroundColor #FFF8E1
    DiamondBorderColor #E6A817
    StartColor #333333
    EndColor #333333
}

title Пользовательский сценарий — Калькулятор реликвий

start

:Открытие приложения\n«Калькулятор реликвий»;

:Главный экран\n──────────────────────\nСекция «Ваши сеты»\nСписок сохранённых сетов\n(или «Нет добавленных сетов»)\nКнопка «+ Добавить сет»;

switch (Действие пользователя?)

case ( Добавить сет )
    :Модалка «Создание сета»\nКнопка «Выбрать персонажа»;
    :Нажатие «Выбрать персонажа»\n→ появляется список персонажей;
    :Список персонажей\nс иконками и именами;
    :Клик по персонажу\n→ модалка «Создание сета» закрыта;
    :Инициализация пустых\nданных для 6 слотов;

case ( Открыть сет )
    :Поиск сета и персонажа по ID;
    :Загрузка сохранённых\nданных артефактов (loadSetIntoPieceData);

case ( Удалить сет )
    :sets.filter() → renderSets()\nСет удалён из списка;
    stop

case ( Закрыть вкладку )
    stop

endswitch

:Модалка артефактов\n──────────────────────\nSplash-art и имя персонажа\n6 карточек: Голова, Перчатки, Тело,\nБотинки, Сфера, Верёвка;

switch (Действие в модалке артефактов?)

case ( Клик «+» на карточке\n— выбор сета )
    :Список Cavern / Planar сетов\nдля данного слота;
    :Выбор сета\n→ selectSet() → updateCardDisplay();

case ( Клик «Главный стат» )
    while (Сет выбран?) is (нет)
        :Предупреждение:\n«Сначала выберите сет»;
    endwhile
    -> да;
    :Список главных статов для слота;
    :Выбор стата\n→ updateCardDisplay();

case ( Клик «—» на подстате )
    while (Сет выбран?) is (нет)
        :Предупреждение:\n«Сначала выберите сет»;
    endwhile
    -> да;
    :Шаг 1 — список доступных подстатов\n(без главного стата и уже выбранных);
    :Шаг 2 — выбор проков (0–5)\nи качества (Низкий / Средний / Высокий);
    :Подтверждение\n→ updateCardDisplay();

endswitch

:Шанс выпадения пересчитан\nи отображён на карточке;
note right
    Пересчитывается при каждом
    изменении сета, стата или подстата
end note

:Нажатие «Сохранить сет»;

while (Персонаж выбран?) is (нет)
    :Предупреждение:\n«Выберите персонажа»;
endwhile
-> да;

:Модалка «Название сета»\nПоле ввода\n(для редактирования — текущее имя предзаполнено);

while (Название введено?) is (нет)
    :Ввод названия → нажатие «Сохранить»;
    :Предупреждение:\n«Введите название сета»;
endwhile
-> да;

if (Редактирование\nсуществующего сета?) then (да)
    :Обновление существующего сета\n(setName, characterId, pieces);
else (нет)
    :Добавление нового сета в массив\n(id: Date.now(), setName, characterId, pieces);
endif

:renderSets()\nМодалки закрыты\nВозврат на главный экран;

:Сет в списке:\nимя, фото персонажа\nКнопки «Открыть» и «Удалить»;

stop

@enduml
