@startuml user_flow
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam dpi 150
skinparam shadowing false
skinparam ArrowColor #333333

skinparam activity {
  BorderColor #444444
  BackgroundColor #F9FBFF
  FontColor #1A1A1A
  DiamondBackgroundColor #FFF3D9
  DiamondBorderColor #C89A2B
  StartColor #76C893
  EndColor #F28482
}

title Диаграмма пользовательского потока (API + авторизация)

start

:Открыть приложение;
:Выбрать персонажа;

if (Есть аккаунт?) then (Да)
  :Нажать "Войти";
  :Ввести email и пароль;
  :POST /api/auth/login;
  if (Успешно?) then (Да)
    :Сохранить JWT access token;
    :GET /api/auth/me (профиль);
  else (Нет)
    :Показать ошибку логина;
    stop
  endif
else (Нет)
  :Продолжить как гость;
  :POST /api/auth/register;
endif

:Выбрать сет реликвий;
:Выбрать главный стат;
:Добавить подстаты;
:Рассчитать шанс выпадения;

if (Сохранить билд?) then (Да)
  if (Авторизован?) then (Да)
    :POST /api/builds;
    :Получить id и share-код;
    :Сгенерировать share-ссылку;
    if (Редактировать позже?) then (Да)
      :PUT /api/builds/:id;
      :Обновить теги и куски;
    endif
    if (Удалить билд?) then (Да)
      :DELETE /api/builds/:id;
    endif
    if (Отметить как полученный?) then (Да)
      :PATCH /api/builds/:id/pieces/:slot/obtained;
    endif
  else (Нет)
    :Показать запрос на вход;
  endif
endif

if (Открыть по share-ссылке?) then (Да)
  :GET /api/builds/share/:code;
  :Просмотр публичной сборки;
endif

:Просмотр публичных билдов;
:GET /api/builds/public;

stop
@enduml
