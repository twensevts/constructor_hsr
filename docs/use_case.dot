digraph UseCase {
    rankdir=LR;
    graph [fontname="Arial", fontsize=12, label="Диаграмма вариантов использования - API и авторизация", labelloc=t];
    node [fontname="Arial", fontsize=11];
    edge [fontname="Arial", fontsize=10, color="#333333"];

    Guest [label="Гость", shape=box, style="rounded"];
    User [label="Авторизованный\\nпользователь", shape=box, style="rounded"];

    subgraph cluster_system {
        label="System: HSR Relic Calculator";
        color="#4A7FA5";
        fontname="Arial";
        fontsize=11;

        UC_ViewPublic [label="Просматривать\\nпубличные билды", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_OpenShare [label="Открывать билд\\nпо share-ссылке", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_Register [label="Зарегистрироваться", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_Login [label="Войти", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_Profile [label="Получить профиль", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];

        UC_CreateBuild [label="Создать билд", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_EditBuild [label="Редактировать свой билд", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_DeleteBuild [label="Удалить свой билд", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_MarkObtained [label="Отметить полученное", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_ManageTags [label="Управлять тегами", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];

        UC_ConfigArtifacts [label="Настроить\\nартефакты", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_SelectSet [label="Выбрать сет реликвий", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_SelectMain [label="Выбрать главный стат", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_SelectSub [label="Выбрать подстаты", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_CalcChance [label="Рассчитать шанс\\nвыпадения", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_SaveApi [label="Сохранить билд\\nв API", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
        UC_Share [label="Получить share-ссылку", shape=ellipse, style="filled", fillcolor="#EEF4FA", color="#4A7FA5", fontcolor="#1A1A1A"];
    }

    Guest -> UC_ViewPublic;
    Guest -> UC_OpenShare;
    Guest -> UC_Register;
    Guest -> UC_Login;
    Guest -> UC_CreateBuild;

    User -> UC_Profile;
    User -> UC_CreateBuild;
    User -> UC_EditBuild;
    User -> UC_DeleteBuild;
    User -> UC_MarkObtained;
    User -> UC_ViewPublic;
    User -> UC_OpenShare;

    UC_Login -> UC_Profile [style=dashed, label="<<include>>"];

    UC_CreateBuild -> UC_ConfigArtifacts [style=dashed, label="<<include>>"];
    UC_CreateBuild -> UC_SaveApi [style=dashed, label="<<include>>"];
    UC_CreateBuild -> UC_ManageTags [style=dashed, label="<<include>>"];
    UC_CreateBuild -> UC_Share [style=dashed, label="<<extend>>"];

    UC_EditBuild -> UC_ConfigArtifacts [style=dashed, label="<<include>>"];
    UC_EditBuild -> UC_SaveApi [style=dashed, label="<<include>>"];
    UC_EditBuild -> UC_ManageTags [style=dashed, label="<<include>>"];
    UC_EditBuild -> UC_Share [style=dashed, label="<<extend>>"];

    UC_ConfigArtifacts -> UC_SelectSet [style=dashed, label="<<include>>"];
    UC_ConfigArtifacts -> UC_SelectMain [style=dashed, label="<<include>>"];
    UC_ConfigArtifacts -> UC_SelectSub [style=dashed, label="<<include>>"];
    UC_CalcChance -> UC_ConfigArtifacts [style=dashed, label="<<extend>>"];
}
