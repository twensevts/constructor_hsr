# ──────────────────────────────────────────
# HSR Constructor API — переменные окружения
# Скопируйте в .env и заполните значения
# ──────────────────────────────────────────

# Сервер
PORT=3000
NODE_ENV=development

# База данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hsr_constructor
DB_USER=postgres
DB_PASS=your_password
DB_POOL_MAX=10

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# CORS (укажите домен фронтенда; * — разрешить все)
CORS_ORIGIN=http://localhost:5500
